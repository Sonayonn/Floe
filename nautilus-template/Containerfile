# --- kmstool_enclave_cli (floe-nav): the attestation-gated KMS client sealed_key.rs shells out to. ---
# Mirrors aws/aws-nitro-enclaves-sdk-c containers/Dockerfile.al2 (SAME pinned refs) but built STATIC
# against musl on alpine instead of dynamic against glibc on AL2 — a glibc binary can't load in the musl
# initramfs below. The single static binary is copied to initramfs/usr/bin/kmstool_enclave_cli (sealed_key.rs:KMSTOOL).
#
# CAVEATS (read before rebuilding):
#  • alpine is NOT a StageX image, so THIS stage is not bit-reproducible like the rest — PCR0 is fixed by
#    this one build. That's fine for Floe: build once, re-anchor (scripts/boot/re-anchor.sh), never rebuild.
#  • This is the ONE stage that can't be validated from the dev box. Static-linking the aws-c stack + aws-lc
#    on musl can need iteration (link order, the nsm-api C lib). Build it FIRST on EC2 and confirm
#    `file /kmstool_enclave_cli` says "statically linked" before building the full .eif.
FROM alpine:3.20 AS kmstool
RUN apk add --no-cache git cmake ninja make gcc g++ musl-dev linux-headers perl go bash cargo
ENV CMAKE_ARGS="-DCMAKE_PREFIX_PATH=/usr -DCMAKE_INSTALL_PREFIX=/usr -DBUILD_TESTING=0 -DBUILD_SHARED_LIBS=0 -GNinja"
WORKDIR /src
RUN set -eux; \
    build() { git clone --depth 1 -b "$2" "$1" "$3"; cmake -S "$3" -B "$3/build" $CMAKE_ARGS ${4:-}; cmake --build "$3/build" --target install; }; \
    build https://github.com/awslabs/aws-lc.git                v1.12.0              aws-lc; \
    build https://github.com/aws/s2n-tls.git                   v1.3.46              s2n-tls; \
    build https://github.com/awslabs/aws-c-common.git          v0.8.0               aws-c-common; \
    build https://github.com/awslabs/aws-c-sdkutils.git        v0.1.2               aws-c-sdkutils; \
    build https://github.com/awslabs/aws-c-cal.git             v0.5.18              aws-c-cal; \
    build https://github.com/awslabs/aws-c-io.git              v0.11.0              aws-c-io; \
    build https://github.com/awslabs/aws-c-compression.git     v0.2.14              aws-c-compression; \
    build https://github.com/awslabs/aws-c-http.git            v0.7.6               aws-c-http; \
    build https://github.com/awslabs/aws-c-auth.git            v0.6.15              aws-c-auth; \
    build https://github.com/json-c/json-c.git                 json-c-0.16-20220414 json-c
# nsm-api is a Rust/Cargo project (no CMakeLists.txt) — build the C lib with cargo, not the build() helper.
# v0.4.0 nsm-lib is crate-type = [staticlib, cdylib, rlib]; copy only the .a so the kmstool link stays static.
RUN set -eux; \
    git clone --depth 1 -b v0.4.0 https://github.com/aws/aws-nitro-enclaves-nsm-api.git; \
    cd aws-nitro-enclaves-nsm-api; \
    cargo build --release --jobs "$(nproc)" -p nsm-lib; \
    cp target/release/libnsm.a /usr/lib/; \
    cp target/release/nsm.h /usr/include/
RUN set -eux; \
    git clone --depth 1 https://github.com/aws/aws-nitro-enclaves-sdk-c.git; \
    cmake -S aws-nitro-enclaves-sdk-c -B aws-nitro-enclaves-sdk-c/build $CMAKE_ARGS; \
    cmake --build aws-nitro-enclaves-sdk-c/build --target install; \
    cp /usr/bin/kmstool_enclave_cli /kmstool_enclave_cli; \
    file /kmstool_enclave_cli || true

FROM scratch AS base
COPY --from=core-busybox . /
COPY --from=core-musl . /
COPY --from=core-libunwind . /
COPY --from=core-openssl . /
COPY --from=core-zlib . /
COPY --from=core-ca-certificates . /
COPY --from=core-libzstd . /
COPY --from=core-binutils . /
COPY --from=core-pkgconf . /
COPY --from=core-git . /
COPY --from=core-rust . /
COPY --from=user-gen_initramfs . /
COPY --from=user-eif_build . /
COPY --from=core-llvm . /
COPY --from=core-libffi . /
COPY --from=core-gcc . /
COPY --from=user-cpio . /
COPY --from=user-linux-nitro /bzImage .
COPY --from=user-linux-nitro /linux.config .

FROM base AS build
COPY . .

WORKDIR /src/nautilus-server
ENV OPENSSL_STATIC=true
ENV TARGET=x86_64-unknown-linux-musl
ARG ENCLAVE_APP
ENV RUSTFLAGS="-C target-feature=+crt-static -C relocation-model=static -C target-cpu=x86-64"
RUN cargo build --locked --no-default-features --features $ENCLAVE_APP --release --target "$TARGET"

WORKDIR /build_cpio
ENV KBUILD_BUILD_TIMESTAMP=1
RUN mkdir initramfs/
# Built-in as of latest linux-nitro
# COPY --from=user-linux-nitro /nsm.ko initramfs/nsm.ko
COPY --from=core-busybox . initramfs
COPY --from=core-python . initramfs
COPY --from=core-musl . initramfs
COPY --from=core-ca-certificates /etc/ssl/certs initramfs
COPY --from=core-busybox /bin/sh initramfs/sh
COPY --from=user-jq /bin/jq initramfs
COPY --from=user-socat /bin/socat . initramfs
COPY --from=user-nit /bin/init initramfs
# floe-nav: the static KMS client sealed_key.rs invokes at /usr/bin/kmstool_enclave_cli
COPY --from=kmstool /kmstool_enclave_cli initramfs/usr/bin/kmstool_enclave_cli
RUN cp /src/nautilus-server/target/${TARGET}/release/nautilus-server initramfs
RUN cp /src/nautilus-server/traffic_forwarder.py initramfs/
RUN cp /src/nautilus-server/run.sh initramfs/

COPY <<-EOF initramfs/etc/environment
SSL_CERT_FILE=/ca-certificates.crt
PATH=/bin:/sbin:/usr/bin:/usr/sbin:/
EOF

RUN <<-EOF
    set -eux
    cd initramfs
    find . -exec touch -hcd "@0" "{}" + -print0 \
    | sort -z \
    | cpio \
        --null \
        --create \
        --verbose \
        --reproducible \
        --format=newc \
    | gzip --best \
    > /build_cpio/rootfs.cpio
EOF

WORKDIR /build_eif
RUN eif_build \
	--kernel /bzImage \
	--kernel_config /linux.config \
	--ramdisk /build_cpio/rootfs.cpio \
	--pcrs_output /nitro.pcrs \
	--output /nitro.eif \
	--cmdline 'reboot=k initrd=0x2000000,3228672 root=/dev/ram0 panic=1 pci=off nomodules console=ttyS0 i8042.noaux i8042.nomux i8042.nopnp i8042.dumbkbd nit.target=/run.sh'

FROM base AS install
WORKDIR /rootfs
COPY --from=build /nitro.eif .
COPY --from=build /nitro.pcrs .
COPY --from=build /build_cpio/rootfs.cpio .

FROM scratch AS package
COPY --from=install /rootfs .
